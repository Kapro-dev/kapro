module kapro.io/plugins/rancher

go 1.25.0

require (
	// Rancher Norman REST client — minimal; no Rancher SDK dep needed.
	// We speak directly to the Rancher v3 REST API over HTTP.
	google.golang.org/grpc v1.80.0

	// K8s client for self-registering the PluginRegistration CR.
	k8s.io/apimachinery v0.35.2
	k8s.io/client-go v0.35.2

	// kapro public interfaces — the ONLY import from the core module.
	// Heavy deps (cosign, ORAS, etc.) stay in the core module and do NOT
	// bleed into this plugin.
	kapro.io/kapro v0.0.0
	sigs.k8s.io/controller-runtime v0.23.3
)

