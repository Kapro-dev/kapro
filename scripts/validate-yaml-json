#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "open3"
require "tempfile"
require "yaml"
require "date"

ROOT = File.expand_path("..", __dir__)
Dir.chdir(ROOT)

YAML_PATTERNS = [
  ".github/workflows/*.yml",
  "examples/**/*.yaml"
].freeze

GRAFANA_JSON_PATTERNS = [
  "examples/monitoring/*.json"
].freeze

SCRIPT_PATTERNS = [
  "scripts/*.sh",
  "examples/**/*.sh"
].freeze

KAPRO_API_VERSION = "kapro.io/v1alpha1"
KAPRO_RUNTIME_API_VERSION = "runtime.kapro.io/v1alpha1"
KAPRO_KINDS = %w[
  Approval
  Cluster
  ClusterTemplate
  Fleet
  Plan
  Plugin
  Policy
  Promotion
  Source
  Substrate
  SubstrateClass
  Trigger
].freeze
KAPRO_RUNTIME_KINDS = %w[
  DecisionTrace
  PromotionRun
  Target
].freeze
STALE_KAPRO_KINDS = %w[
  Backend
  BackendProfile
  FleetCluster
  FleetClusterTemplate
  FleetDriftReport
  GateExpression
  PluginRegistration
  PromotionPlan
  PromotionSource
  PromotionTarget
  PromotionTrigger
].freeze
STALE_KAPRO_FIELDS = %w[
  kaproRef
  backendRef
  promotionPlan
  promotionPlans
  promotionrunTemplate
].freeze
STALE_KUBECTL_RESOURCES = %w[
  backendprofile
  backendprofiles
  backend
  backends
  fleetdriftreport
  fleetdriftreports
  gateexpression
  gateexpressions
  fleetcluster
  fleetclusters
  pluginregistration
  pluginregistrations
  promotionplan
  promotionplans
  promotionsource
  promotionsources
  promotiontarget
  promotiontargets
  promotiontrigger
  promotiontriggers
].freeze
STALE_MONITORING_TEXT = %w[
  kapro_promotiontrigger
  kapro_pluginregistration
  $labels.promotiontrigger
  $labels.pluginregistration
  runbook-blocked-promotiontrigger
].freeze

def matching_files(patterns)
  files = []

  patterns.each do |pattern|
    matches = Dir.glob(pattern).sort
    raise "no files matched #{pattern}" if matches.empty?

    files.concat(matches)
  end

  files.uniq.sort
end

def validate_yaml(path)
  YAML.parse_file(path)
end

def yaml_documents(path)
  YAML.load_stream(File.read(path))
end

def validate_json(path)
  JSON.parse(File.read(path))
end

def promtool_available?
  system("promtool", "--version", out: File::NULL, err: File::NULL)
end

def kapro_document?(doc)
  api = doc["apiVersion"]
  api.is_a?(String) && (api.start_with?("kapro.io/") || api.start_with?("runtime.kapro.io/"))
end

def check_kapro_yaml(path)
  failures = []

  yaml_documents(path).each_with_index do |doc, index|
    next unless doc.is_a?(Hash)
    next unless kapro_document?(doc) || STALE_KAPRO_KINDS.include?(doc["kind"])

    location = "#{path}: document #{index + 1}"
    api = doc["apiVersion"]
    kind = doc["kind"]

    if STALE_KAPRO_KINDS.include?(kind)
      failures << "#{location}: stale Kapro kind #{kind.inspect}"
    elsif KAPRO_KINDS.include?(kind)
      if api != KAPRO_API_VERSION
        failures << "#{location}: Kapro apiVersion is #{api.inspect}, want #{KAPRO_API_VERSION}"
      end
    elsif KAPRO_RUNTIME_KINDS.include?(kind)
      if api != KAPRO_RUNTIME_API_VERSION
        failures << "#{location}: Kapro runtime apiVersion is #{api.inspect}, want #{KAPRO_RUNTIME_API_VERSION}"
      end
    else
      failures << "#{location}: unknown Kapro kind #{kind.inspect}"
    end

    stale_field_paths(doc).each do |field_path|
      failures << "#{location}: stale Kapro field #{field_path}"
    end
  end

  failures
end

def stale_field_paths(value, prefix = [])
  case value
  when Hash
    value.flat_map do |key, nested|
      path = prefix + [key.to_s]
      failures = STALE_KAPRO_FIELDS.include?(key.to_s) ? [path.join(".")] : []
      failures + stale_field_paths(nested, path)
    end
  when Array
    value.each_with_index.flat_map { |nested, index| stale_field_paths(nested, prefix + [index]) }
  else
    []
  end
end

def check_script_kubectl_resources(path)
  stale_re = Regexp.union(STALE_KUBECTL_RESOURCES)
  failures = []
  File.readlines(path).each_with_index do |line, index|
    next unless line.include?("kubectl") || line.include?("KUBECTL")
    next unless line.match?(/\b#{stale_re}\b/)

    failures << "#{path}:#{index + 1}: stale kubectl Kapro resource in #{line.strip.inspect}"
  end
  failures
end

def check_monitoring_public_names(path)
  return [] unless path.start_with?("examples/monitoring/")

  text = File.read(path)
  failures = []
  STALE_MONITORING_TEXT.each do |stale|
    failures << "#{path}: stale monitoring public name #{stale.inspect}" if text.include?(stale)
  end
  failures
end

def prometheus_rule_groups_for(doc)
  return doc["groups"] if doc.is_a?(Hash) && doc["groups"].is_a?(Array)

  return nil unless doc.is_a?(Hash)
  return nil unless doc["apiVersion"] == "monitoring.coreos.com/v1"
  return nil unless doc["kind"] == "PrometheusRule"

  doc.dig("spec", "groups")
end

def check_prometheus_rule_shape(path, groups)
  failures = []

  unless groups.is_a?(Array) && groups.any?
    return ["#{path}: Prometheus rules must contain at least one group"]
  end

  groups.each_with_index do |group, group_index|
    location = "#{path}: groups[#{group_index}]"
    unless group.is_a?(Hash)
      failures << "#{location}: group must be a mapping"
      next
    end

    failures << "#{location}.name must be set" unless group["name"].is_a?(String) && !group["name"].empty?
    rules = group["rules"]
    unless rules.is_a?(Array) && rules.any?
      failures << "#{location}.rules must contain at least one rule"
      next
    end

    rules.each_with_index do |rule, rule_index|
      rule_location = "#{location}.rules[#{rule_index}]"
      unless rule.is_a?(Hash)
        failures << "#{rule_location}: rule must be a mapping"
        next
      end

      has_alert = rule["alert"].is_a?(String) && !rule["alert"].empty?
      has_record = rule["record"].is_a?(String) && !rule["record"].empty?
      failures << "#{rule_location}: exactly one of alert or record must be set" if has_alert == has_record
      failures << "#{rule_location}.expr must be set" unless rule["expr"].is_a?(String) && !rule["expr"].strip.empty?
    end
  end

  failures
end

def check_prometheus_rules_with_promtool(path, groups)
  return [] unless promtool_available?

  Tempfile.create(["kapro-prometheus-rules", ".yaml"]) do |file|
    file.write(YAML.dump("groups" => groups))
    file.flush

    output, status = Open3.capture2e("promtool", "check", "rules", file.path)
    return [] if status.success?

    return ["#{path}: promtool check rules failed after preparing rule groups:\n#{output}"]
  end
end

def check_prometheus_rules(path)
  failures = []

  yaml_documents(path).each_with_index do |doc, index|
    groups = prometheus_rule_groups_for(doc)
    next if groups.nil?

    location = "#{path}: document #{index + 1}"
    failures.concat(check_prometheus_rule_shape(location, groups))
    failures.concat(check_prometheus_rules_with_promtool(location, groups))
  end

  failures
end

failures = []
begin
  yaml_files = matching_files(YAML_PATTERNS)
  json_files = matching_files(GRAFANA_JSON_PATTERNS)
  script_files = matching_files(SCRIPT_PATTERNS)
rescue RuntimeError => e
  warn "YAML/JSON validation failed: #{e.message}"
  exit 1
end

yaml_files.each do |path|
  validate_yaml(path)
  failures.concat(check_kapro_yaml(path))
  failures.concat(check_monitoring_public_names(path))
  failures.concat(check_prometheus_rules(path))
rescue Psych::Exception => e
  failures << "#{path}: #{e.message}"
end

json_files.each do |path|
  validate_json(path)
  failures.concat(check_monitoring_public_names(path))
rescue JSON::ParserError => e
  failures << "#{path}: #{e.message}"
end

script_files.each do |path|
  failures.concat(check_script_kubectl_resources(path))
end

if failures.any?
  warn "YAML/JSON validation failed:"
  failures.each { |failure| warn "  #{failure}" }
  exit 1
end

puts "Validated #{yaml_files.length} YAML files, #{json_files.length} Grafana dashboard JSON files, and #{script_files.length} scripts."
