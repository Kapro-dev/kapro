#!/bin/sh
# Pre-commit hook: runs the same checks as CI.
# Install: make hooks
# Skip when needed: git commit --no-verify
#
# KAPRO_HOOK_FAST=1 git commit  - skip lint and test (gofmt + vet + build only)
# KAPRO_HOOK_COVERAGE=1 git commit  - run coverage test target instead of local no-cover target

set -e

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -z "$STAGED" ]; then
    exit 0
fi

echo "pre-commit: gofmt..."
UNFORMATTED=$(gofmt -l $STAGED)
if [ -n "$UNFORMATTED" ]; then
    echo "  needs formatting:"
    echo "$UNFORMATTED"
    echo "  run: make fmt"
    exit 1
fi

echo "pre-commit: go vet..."
go vet ./...

echo "pre-commit: go build..."
go build ./...

# Check if types.go changed - if so, verify manifests are up to date
if echo "$STAGED" | grep -q "types.go"; then
    echo "pre-commit: types.go changed, verifying generated manifests..."
    make generate manifests 2>/dev/null
    if ! git diff --quiet config/crd/ api/v1alpha1/zz_generated.deepcopy.go 2>/dev/null; then
        echo "  CRD manifests or deepcopy are out of date."
        echo "  run: make generate manifests && git add config/ api/"
        exit 1
    fi
fi

if [ "${KAPRO_HOOK_FAST:-}" = "1" ]; then
    echo "pre-commit: passed (fast mode, skipped lint+test)"
    exit 0
fi

echo "pre-commit: golangci-lint..."
make lint

echo "pre-commit: go test..."
if [ "${KAPRO_HOOK_COVERAGE:-}" = "1" ]; then
    make test
else
    make test-no-cover
fi

echo "pre-commit: passed"
