#!/bin/sh
# Pre-commit hook: runs gofmt, go vet, and build on staged Go files.
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or:      make hooks

set -e

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -z "$STAGED" ]; then
    exit 0
fi

echo "pre-commit: checking Go files..."

# Check formatting
UNFORMATTED=$(gofmt -l $STAGED)
if [ -n "$UNFORMATTED" ]; then
    echo "pre-commit: gofmt failed on:"
    echo "$UNFORMATTED"
    echo "Run: gofmt -w \$(git diff --cached --name-only | grep '\\.go$')"
    exit 1
fi

# Vet
echo "pre-commit: go vet..."
go vet ./...

# Build
echo "pre-commit: go build..."
go build ./...

echo "pre-commit: all checks passed"
