#!/bin/sh
# Pre-commit hook: runs the same checks as CI.
# Install: make hooks
# Skip when needed: git commit --no-verify
#
# KAPRO_HOOK_FAST=1 git commit  - skip lint and test (gofmt + vet + build only)

set -e

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -z "$STAGED" ]; then
    exit 0
fi

echo "pre-commit: gofmt..."
UNFORMATTED=$(gofmt -l $STAGED)
if [ -n "$UNFORMATTED" ]; then
    echo "  needs formatting:"
    echo "$UNFORMATTED"
    echo "  run: make fmt"
    exit 1
fi

echo "pre-commit: go vet..."
go vet ./...

echo "pre-commit: go build..."
go build ./...

if [ "${KAPRO_HOOK_FAST:-}" = "1" ]; then
    echo "pre-commit: passed (fast mode, skipped lint+test)"
    exit 0
fi

echo "pre-commit: golangci-lint..."
make lint

echo "pre-commit: go test..."
make test

echo "pre-commit: passed (full CI parity)"
